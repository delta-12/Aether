<?xml version="1.0"?>
<suppressions>

    <!-- Suppress missing includes -->
    <suppress>
        <id>missingInclude</id>
    </suppress>
    <suppress>
        <id>missingIncludeSystem</id>
    </suppress>

    <!-- Suppress unused functions -->
    <suppress>
        <id>unusedFunction</id>
    </suppress>

    <!-- Suppress static linkage for functions to be used outside of translation unit -->
    <suppress>
        <id>staticFunction</id>
        <symbolName>a_Buffer_AppendRight</symbolName>
    </suppress>

    <!-- Suppress parameter can be declared as pointer to const -->
    <suppress>
        <id>constParameterPointer</id>
        <fileName>*/src/memory.c</fileName>
    </suppress>

</suppressions>
